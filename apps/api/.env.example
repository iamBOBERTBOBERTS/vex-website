DATABASE_URL="postgresql://user:password@localhost:5432/vex"
# Same as DATABASE_URL locally; use direct Postgres (non-pooler) for migrations when using PgBouncer/Accelerate.
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/vex"
# Comma-separated read replica URLs for future read routing (documented; app uses DATABASE_URL today).
READ_REPLICA_URLS=

# Redis — queues (BullMQ), refresh tokens, JWT blacklist, distributed rate limits
REDIS_URL=

# Upstash-compatible REST rate limiting (optional; falls back to Redis/ioredis or in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

JWT_SECRET="your-secret-key-change-in-production"
# Access token TTL minutes (default 5). Refresh tokens are long-lived in Redis.
JWT_ACCESS_TTL_MINUTES=5
PORT=3001
# Comma-separated origins for CORS (e.g. "https://app.dealer.com,https://crm.dealer.com"). In production use real origins, not "*".
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
NODE_ENV=development

# Local/dev only: allow API to start without Edmunds + MarketCheck keys (never set in production).
# SKIP_VALUATION_ENV_CHECK=1

# Public trade-in estimates (marketing /checkout) when host does not map to a tenant via custom domain
PUBLIC_APPRAISAL_TENANT_ID=

# Third-party vehicle valuation (required in production unless SKIP_VALUATION_ENV_CHECK is set)
EDMUNDS_API_KEY=
EDMUNDS_SECRET=
MARKETCHECK_API_KEY=

# Stripe (SaaS checkout + webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard (see apps/api/src/lib/stripe.ts)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Optional: secret for /webhooks/sms and /webhooks/email (send as X-Webhook-Secret header or ?secret=)
# WEBHOOK_SECRET=your-secret

# Deployment / platform (PUBLIC_WEB_URL used for Stripe checkout + billing portal return URLs)
PUBLIC_WEB_URL=
NEXT_PUBLIC_WEB_URL=
NEXT_PUBLIC_API_URL=

# Notifications (Resend email + optional SMS placeholder)
RESEND_API_KEY=
RESEND_FROM=
SMS_PROVIDER=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

RATE_LIMIT_POINTS_PER_TENANT=1000
RATE_LIMIT_WINDOW_SEC=60
ONBOARDING_CAPTCHA_SECRET=
PILOT_AUTO_APPROVE_LIMIT=20