generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Primary URL — use `prisma://` (Prisma Accelerate) or `postgresql://` with PgBouncer in production.
  url       = env("DATABASE_URL")
  /// Direct Postgres URL for migrations and long-running scripts (bypass pooler). Optional in dev.
  directUrl = env("DIRECT_DATABASE_URL")
}

/// Read replica URLs for app-level routing (Prisma Client uses `url` above; route heavy read paths manually).
/// Set `READ_REPLICA_URLS` as comma-separated list in ops (documented in README).

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
  GROUP_ADMIN
}

enum UserTier {
  STANDARD
  VIP
}

model Tenant {
  id        String   @id @default(cuid())
  name      String   @unique
  billingTier             String   @default("STARTER") @map("billing_tier")
  stripeSubscriptionStatus String? @map("stripe_subscription_status")
  stripeCustomerId        String? @unique @map("stripe_customer_id")
  stripeSubscriptionId    String? @unique @map("stripe_subscription_id")
  customDomain            String? @unique @map("custom_domain")
  themeJson               Json?   @map("theme_json")
  parentTenantId          String? @map("parent_tenant_id")
  holdingCompanyId        String? @map("holding_company_id")
  entityType              String   @default("OPERATING") @map("entity_type")
  consolidatedReporting   Boolean  @default(false) @map("consolidated_reporting")
  locationType            LocationType @default(SINGLE) @map("location_type")
  groupSettings           Json?   @map("group_settings")
  region                  TenantRegion @default(US)
  primaryRegion           TenantRegion @default(US) @map("primary_region")
  supportedRegions        Json?   @map("supported_regions")
  currency                String   @default("USD")
  taxId                   String?  @map("tax_id")
  taxSettings             Json?    @map("tax_settings")
  locale                  String   @default("en-US")
  dataResidency           String   @default("US") @map("data_residency")
  onboardedAt             DateTime? @map("onboarded_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  customers            Customer[]
  vehicles             Vehicle[]
  inventory            Inventory[]
  configurationOptions ConfigurationOption[]
  orders               Order[]
  savedVehicles        SavedVehicle[]
  shipments            Shipment[]
  appraisals           Appraisal[]
  subscriptions        Subscription[]
  notifications        Notification[]
  leads                Lead[]
  checkoutSessions     CheckoutSession[]
  flags                Flag[]
  plans                Plan[]
  valuationCaches      ValuationCache[]
  eventLogs            EventLog[]
  auditLogs            AuditLog[]
  usageLogs            UsageLog[]
  referrals            Referral[]
  growthMetrics        GrowthMetric[]
  complianceReports    ComplianceReport[]
  countryCompliances   CountryCompliance[]
  complianceLogs       ComplianceLog[]
  iterationBacklogItems IterationBacklog[]
  multiEntityLedgerRows MultiEntityLedger[]
  locations            Location[] @relation("LocationTenant")
  groupLocations       Location[] @relation("LocationGroup")

  @@map("tenants")
}

model MultiEntityLedger {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  entityId      String   @map("entity_id")
  ledgerType    String   @map("ledger_type")
  amountUsd     Decimal  @map("amount_usd") @db.Decimal(14, 2)
  currency      String   @default("USD")
  occurredAt    DateTime @map("occurred_at")
  payload       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
  @@index([tenantId, ledgerType, occurredAt])
  @@map("multi_entity_ledger")
}

enum LocationType {
  GROUP
  SINGLE
  DEALERSHIP
}

enum TenantRegion {
  US
  EU
  LATAM
  APAC
  OTHER
}

model Plan {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  code        String
  name        String
  monthlyPrice Decimal @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice  Decimal @map("yearly_price") @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("plans")
}

model Flag {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("flags")
}

model CheckoutSession {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  stripeCheckoutSessionId String  @unique @map("stripe_checkout_session_id")
  mode                  String
  status                String
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("checkout_sessions")
}

/// Marks Stripe webhook events fully applied so retries short-circuit without re-running side effects.
model StripeWebhookEvent {
  id         String   @id @map("stripe_event_id")
  type       String
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("stripe_webhook_events")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole  @default(CUSTOMER)
  name         String?
  phone        String?
  tier         UserTier?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inventoryListings Inventory[] @relation("ListedBy")
  orders           Order[]
  savedVehicles    SavedVehicle[]
  subscriptions   Subscription[]
  notifications   Notification[]
  leadsAssigned   Lead[]          @relation("AssignedTo")
  customerProfile Customer?

  @@index([tenantId])
  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @unique @map("user_id")
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  appraisals Appraisal[]

  @@index([tenantId])
  @@map("customers")
}

model Vehicle {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  make      String
  model     String
  trimLevel String   @map("trim_level")
  year      Int
  basePrice Decimal  @map("base_price") @db.Decimal(12, 2)
  bodyType  String?  @map("body_type")
  imageUrls Json?    @map("image_urls")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inventory            Inventory[]
  configurationOptions ConfigurationOption[]
  orders               Order[]
  appraisals           Appraisal[]

  @@index([tenantId])
  @@map("vehicles")
}

enum InventorySource {
  COMPANY
  PRIVATE_SELLER
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// How the 3D asset was produced — supports future photo→mesh jobs
enum VehicleModelSource {
  LIBRARY
  UPLOAD
  GENERATED_FROM_PHOTOS
}

model Inventory {
  id                 String             @id @default(cuid())
  tenantId           String             @map("tenant_id")
  source             InventorySource
  vehicleId          String             @map("vehicle_id")
  listedByUserId     String?            @map("listed_by_user_id")
  location           String?
  listPrice          Decimal             @map("list_price") @db.Decimal(12, 2)
  mileage            Int?
  status             InventoryStatus    @default(AVAILABLE)
  vin                String?
  verificationStatus VerificationStatus? @map("verification_status")
  imageUrls          Json?              @map("image_urls")
  specs              Json?
  // HTTPS URL to GLB/GLTF (CDN, S3, or /models/…). Viewer loads this mesh.
  modelGlbUrl        String?            @map("model_glb_url")
  modelSource        VehicleModelSource? @map("model_source")
  // IDs of listing photos used to generate modelGlbUrl (future photogrammetry pipeline)
  modelSourcePhotoIds Json?             @map("model_source_photo_ids")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  listedBy      User?          @relation("ListedBy", fields: [listedByUserId], references: [id], onDelete: SetNull)
  orders        Order[]
  savedVehicles SavedVehicle[]

  @@index([tenantId])
  @@map("inventory")
}

enum OptionCategory {
  TIRES
  PAINT
  ACCESSORIES
  STYLING
}

model ConfigurationOption {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  vehicleId   String?        @map("vehicle_id")
  category    OptionCategory
  name        String
  priceDelta  Decimal        @map("price_delta") @db.Decimal(10, 2)
  isRequired  Boolean        @default(false) @map("is_required")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("configuration_options")
}

enum OrderType {
  INVENTORY
  CUSTOM_BUILD
}

enum OrderStatus {
  DRAFT
  DEPOSIT_PAID
  CONFIRMED
  FULFILLED
}

model Order {
  id                    String       @id @default(cuid())
  tenantId              String       @map("tenant_id")
  userId                String       @map("user_id")
  type                  OrderType
  inventoryId           String?      @map("inventory_id")
  vehicleId             String?      @map("vehicle_id")
  configSnapshot        Json?        @map("config_snapshot")
  status                OrderStatus  @default(DRAFT)
  depositAmount         Decimal?     @map("deposit_amount") @db.Decimal(12, 2)
  totalAmount           Decimal?     @map("total_amount") @db.Decimal(12, 2)
  financingSnapshot     Json?        @map("financing_snapshot")
  tradeInSnapshot       Json?        @map("trade_in_snapshot")
  shippingSnapshot      Json?        @map("shipping_snapshot")
  stylingAddonsSnapshot Json?        @map("styling_addons_snapshot")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  vehicle   Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  shipments Shipment[]

  @@index([tenantId])
  @@map("orders")
}

model SavedVehicle {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  userId         String   @map("user_id")
  inventoryId    String?  @map("inventory_id")
  configSnapshot Json?   @map("config_snapshot")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory Inventory? @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("saved_vehicles")
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

enum TransportType {
  OPEN
  ENCLOSED
}

model Shipment {
  id                 String         @id @default(cuid())
  tenantId           String         @map("tenant_id")
  orderId            String         @map("order_id")
  carrier            String?
  trackingUrl        String?        @map("tracking_url")
  status             ShipmentStatus  @default(PENDING)
  estimatedDelivery  DateTime?       @map("estimated_delivery")
  openEnclosed       TransportType   @map("open_enclosed")
  quoteAmount        Decimal?        @map("quote_amount") @db.Decimal(10, 2)
  origin             String?
  destination        String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("shipments")
}

model Appraisal {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  vehicleId  String?   @map("vehicle_id")
  customerId String?   @map("customer_id")
  value      Decimal?  @map("value") @db.Decimal(12, 2)
  notes      String?
  valuationData Json? @map("valuation_data")
  valuationSource String? @default("manual") @map("valuation_source")
  valuationFetchedAt DateTime? @map("valuation_fetched_at")
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([tenantId, valuationFetchedAt])
  @@map("appraisals")
}

enum SubscriptionPlan {
  CHECK_MY_DEAL
  VIP_CONCIERGE
}

model Subscription {
  id              String            @id @default(cuid())
  tenantId         String            @map("tenant_id")
  userId          String            @map("user_id")
  plan            SubscriptionPlan
  status          String            @default("ACTIVE")
  billingInterval String?           @map("billing_interval")
  amount          Decimal?          @map("amount") @db.Decimal(10, 2)
  expiresAt       DateTime?         @map("expires_at")
  stripeCustomerId        String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId    String?   @unique @map("stripe_subscription_id")
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  createdAt       DateTime          @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("notifications")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

model Lead {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  source       String     @default("WEBSITE")
  email        String?
  phone        String?
  name         String?
  vehicleInterest String?  @map("vehicle_interest")
  notes        String?
  status       LeadStatus @default(NEW)
  assignedToId String?    @map("assigned_to_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("leads")
}


model ValuationCache {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  cacheKey  String   @map("cache_key")
  payload   Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Ops: declarative PARTITION BY RANGE (tenant_id) in Postgres 15+ via prisma/sql/tenant_partitions.sql
  @@unique([tenantId, cacheKey])
  @@index([tenantId, expiresAt])
  @@map("valuation_cache")
}

/// Append-only audit/event stream — primary partition key is `tenantId` (hash/range partitions applied in ops SQL).
model EventLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([type, tenantId])
  @@map("event_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  actorId   String?  @map("actor_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([action, tenantId])
  @@map("audit_logs")
}

model UsageLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  kind      String
  quantity  Int      @default(1)
  amountUsd Decimal? @map("amount_usd") @db.Decimal(10, 2)
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind, createdAt])
  @@map("usage_logs")
}

model Referral {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  codeHash   String   @unique @map("code_hash")
  createdBy  String?  @map("created_by")
  uses       Int      @default(0)
  maxUses    Int      @default(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("referrals")
}

model GrowthMetric {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  key       String
  value     Decimal  @db.Decimal(12, 2)
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, key, createdAt])
  @@map("growth_metrics")
}

model Location {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  groupId     String?  @map("group_id")
  name        String
  code        String?
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation("LocationTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  group  Tenant? @relation("LocationGroup", fields: [groupId], references: [id], onDelete: SetNull)

  @@index([tenantId, groupId])
  @@map("locations")
}

model ComplianceReport {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  period     String
  format     String
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, period, createdAt])
  @@map("compliance_reports")
}

model CountryCompliance {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  countryCode      String   @map("country_code")
  framework        String
  status           String   @default("active")
  consentRequired  Boolean  @default(false) @map("consent_required")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, countryCode, framework])
  @@index([tenantId, countryCode])
  @@map("country_compliances")
}

model ComplianceLog {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  actorId        String?  @map("actor_id")
  eventType      String   @map("event_type")
  region         String?
  dataResidency  String?  @map("data_residency")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType, createdAt])
  @@index([tenantId, createdAt])
  @@map("compliance_logs")
}

model IterationBacklog {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  priority    Int      @default(50)
  title       String
  description String
  source      String   @default("analytics")
  status      String   @default("open")
  score       Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, priority])
  @@index([tenantId, createdAt])
  @@map("iteration_backlog")
}
