# Copy to .env.local for local dev (never commit .env.local).
# API origin — must match apps/api and apps/crm.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: dealer hero gold dust (R3F). Set to 0 or false to disable. Default on when WebGL + motion allow.
# NEXT_PUBLIC_HERO_PARTICLES=0

# Cinematic hero v2 is default ON. Set to 0/false to use legacy `DealerProgramHero`.
# NEXT_PUBLIC_CINEMATIC_HERO_V2=0

# GLSL luxury shaders (iridescent flake / clear-coat inject). Set to 0 for standard PBR only.
# NEXT_PUBLIC_CINEMATIC_SHADERS_V3=0

# Dev: stronger bloom + vortex particles. Use root `pnpm dev:web:cinematic` / `pnpm --filter @vex/web run dev:cinematic`
# or `pnpm --filter @vex/web run dev:moat` (same env).
# NEXT_PUBLIC_CINEMATIC_MODE=true

# Cinematic Apex v4 — scroll-linked god-rays, particle formation, speed streaks. Root: `pnpm dev:apex`
# NEXT_PUBLIC_CINEMATIC_APEX=true

# v4.1 GLSL max stack: shaders + Apex + cinematic mode. Root: `pnpm dev:glsl-apex`
# (Sets NEXT_PUBLIC_CINEMATIC_SHADERS_V3, CINEMATIC_APEX, CINEMATIC_MODE via dev script.)

# v4.2: full onBeforeCompile path (LUT + flake + clear-coat). Root: `pnpm dev:apex-v42`
# Add CINEMATIC_APEX / MODE via `dev:glsl-apex` or `.env.local` for particle vortex + god-ray ramp.

# Same secret as API `INTERNAL_PILOT_METRICS_KEY` — enables GET /api/investor/pilot-network
# (server proxy to GET /dealer/pilots). Generate: openssl rand -hex 32
INTERNAL_PILOT_METRICS_KEY=

# Optional: server-only API URL for the investor proxy (defaults to NEXT_PUBLIC_API_URL).
# Use when the browser and Node hit different hosts (e.g. internal service URL in k8s).
# INTERNAL_API_URL=http://api:3001
