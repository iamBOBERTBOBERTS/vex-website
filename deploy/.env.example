# Copy to deploy/.env when using docker compose from this directory.
# The API refuses to start in NODE_ENV=production without a real CORS allowlist and valuation keys.

JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
PUBLIC_WEB_URL=http://localhost:3000

EDMUNDS_API_KEY=
EDMUNDS_SECRET=
MARKETCHECK_API_KEY=

# Optional for billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
