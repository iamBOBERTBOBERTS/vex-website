{
  "name": "@vex/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:cinematic": "NEXT_PUBLIC_CINEMATIC_MODE=true pnpm dev",
    "dev:moat": "NEXT_PUBLIC_CINEMATIC_MODE=true pnpm dev",
    "build": "next build",
    "cinematic:build": "next build",
    "cinematic:hero": "next build",
    "moat:build": "next build",
    "webgpu:build": "next build",
    "glsl:build": "next build",
    "cinematic:apex": "next build",
    "glsl:apex": "next build",
    "glsl:apex-v42": "next build",
    "cinematic:apex-v42": "next build",
    "glsl:apex-v44": "next build",
    "cinematic:apex-v44": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "quality:web": "pnpm run lint && pnpm run test:smoke",
    "test:smoke": "playwright test tests/a11y.spec.ts tests/cinematic-moat.spec.ts tests/cinematic-apex.spec.ts tests/cinematic-v42.spec.ts tests/apex-studio-build.spec.ts",
    "quality:3d": "pnpm run lint",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:lighthouse": "lhci autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "8.18.0",
    "@react-three/postprocessing": "2.16.3",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tanstack/react-query": "5",
    "@theatre/core": "^0.7.2",
    "@theatre/r3f": "^0.7.2",
    "@vex/3d-configurator": "workspace:*",
    "@vex/cinematic": "workspace:*",
    "@vex/design-system": "workspace:*",
    "@vex/shared": "workspace:*",
    "@vex/ui": "workspace:*",
    "framer-motion": "^12.38.0",
    "gsap": "^3.13.0",
    "lenis": "^1.3.13",
    "next": "^16.1.7",
    "postprocessing": "6.39.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-scan": "^0.5.3",
    "sharp": "^0.34.5",
    "three": "0.169.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.0"
  }
}
