# Copy to .env.local for local dev (never commit .env.local).
# API origin — must match apps/api and apps/crm.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Same secret as API `INTERNAL_PILOT_METRICS_KEY` — enables GET /api/investor/pilot-network
# (server proxy to GET /dealer/pilots). Generate: openssl rand -hex 32
INTERNAL_PILOT_METRICS_KEY=

# Optional: server-only API URL for the investor proxy (defaults to NEXT_PUBLIC_API_URL).
# Use when the browser and Node hit different hosts (e.g. internal service URL in k8s).
# INTERNAL_API_URL=http://api:3001
