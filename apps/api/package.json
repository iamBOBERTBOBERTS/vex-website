{
  "name": "@vex/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "env:check": "tsx scripts/check-env.ts",
    "dev": "pnpm run env:check -- --require DATABASE_URL,JWT_SECRET --context dev:api && tsx watch src/index.ts",
    "dev:api": "pnpm run env:check -- --require DATABASE_URL,JWT_SECRET --context dev:api && tsx watch src/index.ts",
    "prebuild": "pnpm run db:generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed.ts",
    "test:e2e": "pnpm run env:check -- --require DATABASE_URL --context test:e2e && tsx scripts/e2e-trust-layer-prisma.ts && tsx scripts/e2e-appraisal-isolation.ts && tsx scripts/e2e-inventory-isolation.ts && tsx scripts/e2e-rbac-guards.ts && tsx scripts/e2e-dealer-integration.ts && tsx scripts/e2e-pilot-loop.ts && tsx scripts/e2e-erp-integration.ts",
    "test:e2e:appraisal": "tsx scripts/e2e-appraisal-isolation.ts",
    "test:e2e:inventory": "tsx scripts/e2e-inventory-isolation.ts",
    "test:e2e:rbac": "tsx scripts/e2e-rbac-guards.ts",
    "test:e2e:dealer": "tsx scripts/e2e-dealer-integration.ts",
    "test:e2e:erp": "tsx scripts/e2e-erp-integration.ts",
    "smoke:cdk-drive": "tsx scripts/cdk-drive-smoke.ts",
    "test:e2e:global": "tsx scripts/e2e-tenant-residency.ts",
    "test:e2e:isolation": "tsx scripts/e2e-tenant-isolation.ts",
    "test:e2e:global-market": "tsx scripts/e2e-global-market-residency.ts",
    "test:global": "tsx scripts/e2e-tenant-residency.ts",
    "test:valuation:unit": "tsx scripts/test-valuation-unit.ts",
    "test:valuation:integration": "tsx scripts/test-valuation-integration.ts",
    "load-test:scale": "tsx scripts/load-test-scale.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "@types/ws": "^8.18.1",
    "@vex/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "stripe": "^21.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.0.0",
    "@types/uuid": "^11.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
